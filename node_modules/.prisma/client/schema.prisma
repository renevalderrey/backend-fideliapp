// Schema de Prisma: define cómo es la base de datos
// Prisma lo lee y crea las tablas automáticamente

generator client {
  provider = "prisma-client-js"
}

// SQLite: base de datos en un archivo local, sin instalar nada
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabla de restaurantes (uno solo en el demo, pero puede escalar)
model Restaurant {
  id            String   @id @default(uuid())
  name          String
  // Cuántos puntos vale cada peso: 1.0 = 1 punto por $1
  pointsPerPeso Float    @default(1.0)
  createdAt     DateTime @default(now())

  // Relaciones: un restaurante tiene muchos clientes y pedidos
  customers Customer[]
  orders    Order[]
}

// Tabla de clientes del restaurante
model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String // Teléfono único para identificar al cliente
  totalPoints Int      @default(0) // Puntos acumulados totales
  createdAt   DateTime @default(now())

  // Relaciones
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  orders       Order[]

  // No puede haber dos clientes con el mismo teléfono en el mismo restaurante
  @@unique([phone, restaurantId])
}

// Tabla de pedidos
model Order {
  id           String   @id @default(uuid())
  amount       Float // Monto del pedido en pesos
  pointsEarned Int // Puntos ganados en este pedido específico
  // Token único que va en el QR: permite al cliente ver este pedido
  qrToken      String   @unique @default(uuid())
  // "pending" = no escaneado aún, "scanned" = el cliente ya lo vio
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  // Relaciones
  customer     Customer   @relation(fields: [customerId], references: [id])
  customerId   String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
}
